# ============================
# Environment Configuration
# ============================

# Node environment
NODE_ENV=development

# Server port (local only, Render sẽ tự set PORT)
PORT=5000

# JWT Secret (phải giống với giá trị trên Render Dashboard)
JWT_SECRET=supersecret123

# ============================
# DATABASE (Filess.io)
# ============================
# Điền DATABASE_URL từ Filess.io vào đây khi chạy local
# Ví dụ: mysql://user:pass@host:port/dbname
DATABASE_URL=

# Nếu không dùng connection string, điền từng trường riêng lẻ:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_DATABASE=english_app
DB_CONNECTION_LIMIT=3

# ============================
# URLs (dùng cho CORS & profile images)
# ============================
# URL của frontend (Netlify/Vercel/...)
FRONTEND_URL=http://localhost:3000

# URL của backend chính nó (dùng để build absolute URL cho ảnh)
BACKEND_URL=http://localhost:5000

# ============================
# Admin
# ============================
ADMIN_EMAIL=admin123@gmail.com